# ============================================================
# AABW Smart Deadline Tracker - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ------------------------------------------------------------
# AI Provider — Groq (REQUIRED)
# Get your free key at: https://console.groq.com/keys
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# AI Model (Optional)
# Default: llama-3.1-8b-instant (fast & free on Groq)
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768
# For AI parse: set AI_PARSE_MODEL for better accuracy
# ------------------------------------------------------------
AI_MODEL=llama-3.1-8b-instant
# AI_PARSE_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------
# Application Settings (Optional)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_NOTIFICATION_POLL_INTERVAL=30000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
